# ──────────────────────────────────────────────────────────────────────────────
# SailPoint Identity Security Cloud — Veza OAA Integration
# Copy this file to .env and fill in the real values.
# NEVER commit the real .env file to source control.
# ──────────────────────────────────────────────────────────────────────────────

# ── SailPoint ISC Configuration ───────────────────────────────────────────────

# Your SailPoint tenant name (the subdomain of identitynow.com)
# Example: if your ISC URL is https://mycompany.identitynow.com, use "mycompany"
SAILPOINT_TENANT=your-tenant-name

# Optional: override the full API base URL (takes precedence over SAILPOINT_TENANT)
# SAILPOINT_URL=https://your-tenant.api.identitynow.com

# OAuth2 Personal Access Token credentials
# Generate a PAT in ISC → Preferences → Personal Access Tokens
# The "Client ID" and "Client Secret" are shown on token creation.
SAILPOINT_CLIENT_ID=your_client_id_here
SAILPOINT_CLIENT_SECRET=your_client_secret_here

# ── Veza Configuration ────────────────────────────────────────────────────────

VEZA_URL=https://your-org.veza.com
VEZA_API_KEY=your_veza_api_key_here

# ── OAA Provider Settings (optional) ─────────────────────────────────────────

# Override the provider name shown in the Veza UI (default: SailPoint)
# PROVIDER_NAME=SailPoint

# Override the datasource name shown in the Veza UI (default: tenant name)
# DATASOURCE_NAME=sailpoint-prod
